headers = SDL3_ttf/SDL_ttf.h
headerFilter = SDL3_ttf/**
depends = sdl3

compilerOpts.osx = -I/opt/homebrew/include
compilerOpts.linux_x64 = -I/usr/include
compilerOpts.linux_arm64 = -I/usr/include

linkerOpts.osx = -L/opt/homebrew/lib -lSDL3_ttf
linkerOpts.linux_x64 = -L/usr/lib/x86_64-linux-gnu -lSDL3_ttf
linkerOpts.linux_arm64 = -L/usr/lib/aarch64-linux-gnu -lSDL3_ttf
# mingw_x64: static-linked in the app executable (demo/apidemo build.gradle.kts)
