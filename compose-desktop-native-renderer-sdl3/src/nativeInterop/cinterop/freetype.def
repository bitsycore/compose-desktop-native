headers = ft2build.h freetype/freetype.h freetype/ftmm.h freetype/ftoutln.h freetype/ftbitmap.h
headerFilter = freetype2/** ft2build.h freetype/**

compilerOpts.osx = -I/opt/homebrew/include/freetype2
compilerOpts.linux_x64 = -I/usr/include/freetype2
compilerOpts.linux_arm64 = -I/usr/include/freetype2
compilerOpts.mingw_x64 = -IC:/Dev/Libs/FreeType/include/freetype2

linkerOpts.osx = -L/opt/homebrew/lib -lfreetype
linkerOpts.linux_x64 = -L/usr/lib/x86_64-linux-gnu -lfreetype
linkerOpts.linux_arm64 = -L/usr/lib/aarch64-linux-gnu -lfreetype
linkerOpts.mingw_x64 = -LC:/Dev/Libs/FreeType/lib -lfreetype
