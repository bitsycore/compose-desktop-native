headers = SDL3/SDL.h
headerFilter = SDL3/**

# Include paths + linker flags are injected from :ui build.gradle.kts using the
# absolute path to <repo>/libs/SDL3 (populated by scripts/build-sdl/build-sdl3.sh).
# The static libSDL3.a is linked into the app executable — see the demo /
# apidemo build.gradle.kts linkerOpts blocks. Same pattern on every target.
